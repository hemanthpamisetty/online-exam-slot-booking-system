# ============================================
# Exam Slot Booking Configuration
# ============================================

# 1. Server Configuration
PORT=3000
NODE_ENV=production
SESSION_SECRET=a_very_long_random_string_for_production_security

# 2. Database Configuration (Shared/Railway)
# Priority: MYSQL_URL > individual vars
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Hemu@123
DB_NAME=exam_system

# 3. Email configuration (SMTP - Brevo Recommended)
# If credentials are missing, the system enters "Safe-Mode"
# and logs emails to the console instead of sending them.
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=your_verified_email@example.com
EMAIL_PASS=your_brevo_smtp_api_key
EMAIL_FROM="ExamSlot Booking <noreply@exam.com>"

# 4. Railway Specifics (Automatically set by Railway if using managed MySQL)
# MYSQL_URL=mysql://...
