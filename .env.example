# ============================================
# Exam Slot Booking Configuration
# Copy this to .env and fill in your values
# ============================================

# 1. Server Configuration
PORT=3000
NODE_ENV=production
SESSION_SECRET=a_very_long_random_string_for_production_security

# 2. Database Configuration (Railway auto-sets MYSQL_URL)
# Priority: MYSQL_URL > individual vars > defaults
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=exam_system

# 3. Email Configuration
# ─── OPTION A: Brevo HTTP API (Recommended, Bypass Railway SMTP block) ───
# 1. Sign up at https://www.brevo.com
# 2. Verify your Sender Email in Brevo Dashboard (CRITICAL!)
# 3. Go to Settings → SMTP & API → Generate an API key (starts with 'xkeysib-')
# 4. Set BREVO_API_KEY below. 
# 5. Make sure EMAIL_FROM is the exact email verified in Brevo.
#
BREVO_API_KEY=xkeysib-your-valid-brevo-api-key
EMAIL_FROM=your_verified_sender@gmail.com

# ─── OPTION B: Gmail Fallback (Testing only) ───
# If BREVO_API_KEY is empty, it falls back to Gmail via SMTP.
#
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_real_gmail@gmail.com
# EMAIL_PASS=your_16_char_app_password
# EMAIL_FROM=your_real_gmail@gmail.com

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# 4. Railway Specifics (Auto-set by Railway if using managed MySQL)
# MYSQL_URL=mysql://user:pass@host:port/db

# 5. App URL (for links in emails)
# APP_URL=https://your-app.up.railway.app
