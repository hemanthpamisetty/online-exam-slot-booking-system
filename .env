# ============================================
# Exam Slot Booking Configuration (Local Dev)
# ============================================

# 1. Server Configuration
PORT=3000
NODE_ENV=development
SESSION_SECRET=local-dev-secret-key-12345

# 2. Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Hemu@123
DB_NAME=exam_system

# 3. Email Configuration
# ─── OPTION A: Brevo HTTP API (Recommended, Bypass Railway SMTP block) ───
# 1. Sign up at https://www.brevo.com
# 2. Verify your Sender Email in Brevo Dashboard (CRITICAL!)
# 3. Go to Settings → SMTP & API → Generate an API key (starts with 'xkeysib-')
# 4. Set BREVO_API_KEY below. 
# 5. Make sure EMAIL_FROM is the exact email verified in Brevo.
#
BREVO_API_KEY=
EMAIL_FROM=

# ─── OPTION B: Gmail Fallback (Testing only) ───
# If BREVO_API_KEY is empty, it falls back to Gmail via SMTP.
#
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_real_gmail@gmail.com
# EMAIL_PASS=your_16_char_app_password
# EMAIL_FROM=your_real_gmail@gmail.com

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
